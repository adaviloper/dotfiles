#!/bin/sh

# Toggle default audio output between Logi Z407 and SteelSeries Arctis 7 Chat

{{- if eq .purpose "work" }}
DESKTOP_SPEAKER="bluez_output.10_94_97_10_C5_93.1"
HEADSET="alsa_output.usb-SteelSeries_SteelSeries_Arctis_7-00.mono-chat"
{{- else }}
DESKTOP_SPEAKER="alsa_output.usb-Logitech_Logi_Z407_00000000-01.analog-stereo"
HEADSET="alsa_output.usb-SteelSeries_SteelSeries_Arctis_7-00.stereo-game"
{{- end }}

current=$(pactl get-default-sink)

if [ "$current" = "$DESKTOP_SPEAKER" ]; then
    next="$HEADSET"
    {{- if eq .purpose "work" }}
    label="SteelSeries Arctis 7 Chat"
    {{- else }}
    label="SteelSeries Arctis 7 Game"
    {{- end }}
else
    next="$DESKTOP_SPEAKER"
    label="Logi Z407"
fi

pactl set-default-sink "$next"
echo "Switched audio output to: $label"
