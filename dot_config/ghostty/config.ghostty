adjust-cell-height = 2

auto-update = check

font-family = Maple Mono NF
font-size = 13.1

gtk-titlebar-style = native

macos-hidden = always
macos-titlebar-style = transparent

theme = Catppuccin Mocha

title = "Ghostty"

window-decoration = none
window-padding-x = 8
window-padding-y = 16
window-save-state = always

config-file = keymaps.ghostty
